{% extends 'template/base.twig' %}

{% block title %}Home Page{% endblock %}

{% block body %}
<div class="p-4 flex flex-col items-start w-full">
    <form method="POST" class="bg-gray-200 p-6 border border-gray-700 w-full max-w-xl">
        <h2 class="text-xl mb-4">Create a New Thread</h2>

        <div class="flex flex-col mb-4 w-full max-w-md">
            <label 
                class="text-sm"
                for="slug"
            >Slug:</label>
            <input 
                class="border border-gray-700 p-2 mt-1 w-full"
                type="text" 
                name="slug" 
                required
            />
        </div>

        <div class="flex flex-col mb-4 w-full max-w-md">
            <label 
                class="text-sm"
                for="name"
            >Name:</label>
            <input 
                class="border border-gray-700 p-2 mt-1 w-full"
                type="text" 
                name="name" 
                required
            />
        </div>
        <button 
            class="bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600"
            type="submit"
        >Create Thread</button>
    </form>
</div>
{% endblock %}
