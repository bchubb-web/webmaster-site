<article data-href="{{ url }}"  class="border border-gray-300 rounded p-4 mb-4 w-full max-w-2xl">
    <div class="flex flex-row gap-4 w-full">
        <section class="flex flex-col gap-2 flex-1">
            <div class="flex flex-col flex-1 gap-1">
                <h2 class="text-md font-bold mb-1">{{ article.title }}</h2>
            </div>
            <footer class="mt-1 h-6 text-sm text-gray-600 flex justify-between items-center gap-4">
                <div id="article-{{ article.id }}-meta" class="flex gap-2">
                    <span>1 like</span>
                    <span>3 comments</span>
                </div>
                <div id="article-{{ article.id }}-extra" class="flex gap-2">
                    <button type="button" class="italic bg-gray-200 size-5 rounded-full text-white hover:bg-gray-300">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 m-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h.01M12 12h.01M19 12h.01M6 12a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0z" />
                        </svg>
                    </button>
                </div>
            </footer>
        </section>
        <div class="flex items-center gap-2">
            <img 
                class="size-32 object-cover bg-gray-200"
                src=""
            />
        </div>
    </div>
</article>
