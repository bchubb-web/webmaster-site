{
    "name": "bchubb-web/webmaster-site",
    "description": "Website builder, the right way",
    "type": "project",
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "authors": [
        {
            "name": "Billy Chubb",
            "email": "billy@bchubb.co.uk"
        }
    ],
    "require": {
        "twig/twig": "^3.21",
        "doctrine/dbal": "^4.3",
        "doctrine/orm": "^3.5",
        "symfony/routing": "^7.3",
        "league/container": "^4.0",
        "league/config": "^1.2",
        "nyholm/psr7": "^1.8",
        "psr/http-server-handler": "^1.0",
        "bchubb-web/webmaster": "dev-main"
    },
    "require-dev": {
        "php-debugbar/php-debugbar": "^2.2"
    },
    "minimum-stability": "dev",
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/bchubb-web/webmaster.git"
        }
    ],
    "scripts": {
        "in-docker": "docker-compose exec site",
        "console": "docker-compose exec site php bin/console.php"
    },
    "config": {
        "preferred-install": {
            "bchubb-web/webmaster": "source",
            "*": "dist"
        }
    }
}
